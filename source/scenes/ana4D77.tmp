script/source = "extends Node

class_name GlobalDate
   
@onready var global_date = Time.get_datetime_dict_from_system();
@onready var hour_degree = global_date.hour * 30;
@onready var minute_degree = global_date.minute * 6;
@onready var second_degree = global_date.second * 6;
	
func _process(delta):
	pass
"

